# === n8n Integration (for Tournament Lifecycle etc.) ===

# Main n8n webhook base (e.g. https://your-n8n-instance.com/webhook)
N8N_WEBHOOK_BASE=https://n8n.yourdomain.com/webhook

# Secret used for all n8n <-> Gament communication
N8N_WEBHOOK_SECRET=super-long-random-secret-1234567890abcdef

# Specific workflow paths (n8n will give you these)
N8N_TOURNAMENT_CREATED_WEBHOOK=/gament-tournament-created
N8N_TOURNAMENT_REMINDER_WEBHOOK=/gament-tournament-reminder
N8N_ERROR_WEBHOOK=/gament-error

# Optional: Your n8n instance for reference
N8N_INSTANCE_URL=https://n8n.yourdomain.com
