# ─────────────────────────────────────────────────────────────
#  gament — environment variables
#  Copy this file to ".env" and fill in real values.
#  NEVER commit the real ".env" file (it is git-ignored).
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (e.g. from Neon).
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# OpenRouter API Key
OPENROUTER_API_KEY="your_openrouter_api_key"

# Groq API Key
GROQ_API_KEY="your_groq_api_key"

# FarazSMS API Configuration (optional for now)
# Current auth works with mobile/username + password. Fill these later when SMS/OTP is enabled.
FARAZSMS_API_KEY="your_api_key_from_farazsms"
FARAZSMS_PATTERN_CODE="your_pattern_code"
FARAZSMS_SENDER="+983000505"

# Telegram bot integration
# Recommended free mode: Telegram webhook runs inside this Next.js web service.
BOT_TOKEN="telegram_bot_token_from_botfather"
TELEGRAM_WEBHOOK_SECRET="change_this_to_another_long_random_secret"
TELEGRAM_ADMIN_IDS="123456789"
TELEGRAM_CHANNEL_URL="https://t.me/Gament_games"
TELEGRAM_CHANNEL_ID="@Gament_games"
TELEGRAM_BOT_USERNAME="GamentTournamentBot"
TELEGRAM_CRON_SECRET="change_this_if_you_use_cron_job_org"
TELEGRAM_REQUIRE_CHANNEL_MEMBERSHIP="false"
# Optional legacy/server-to-server integration for the Python worker bot.
TELEGRAM_INTEGRATION_SECRET="change_this_to_a_long_random_secret"
# Required in production before calling POST /api/admin/setup to bootstrap the first super admin.
ADMIN_SETUP_SECRET="change_this_to_a_long_random_secret"
# Optional but recommended before enabling SMS OTP; used as a pepper for OTP hashes.
OTP_TOKEN_PEPPER="change_this_to_a_different_long_random_secret"

# Optional: secret for internal AI/automation endpoints that suggest Hall of Fame items.
HONORS_AI_SECRET="change_this_to_a_long_random_secret"

# Optional: Cloudinary upload for admin media manager
# If not set, small images can still be stored as data URLs.
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Optional: enable hourly auto-scan of Divar/Sheypoor for gaming ads.
# Set to "true" only after you have applied the classified_ads migration.
CLASSIFIED_AUTO_SCAN_ENABLED="false"
# How often to scan (in hours). Default is 1.
CLASSIFIED_SCAN_INTERVAL_HOURS="1"
# Scan all cities (true) or only Tehran (false).
CLASSIFIED_SCAN_ALL_CITIES="false"
# Max ads per city per scan. Keep low to avoid IP/rate-limit bans.
CLASSIFIED_LIMIT_PER_CITY="5"
# Optional HTTP proxy for classified scraping (e.g. http://user:pass@proxy:8080).
CLASSIFIED_PROXY_URL=""
# Optional: comma-separated keywords. If set, only ads containing at least one are kept.
CLASSIFIED_WHITELIST_KEYWORDS=""
# Optional: comma-separated keywords. Ads containing any of these are skipped.
CLASSIFIED_BLACKLIST_KEYWORDS=""
# Delete classified ads older than N days. Default 7, set 0 to disable.
CLASSIFIED_ADS_MAX_AGE_DAYS="7"

# Node environment: development | production
NODE_ENV="development"
