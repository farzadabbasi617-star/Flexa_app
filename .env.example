# ─────────────────────────────────────────────────────────────
#  Flexa_app — environment variables
#  Copy this file to ".env" and fill in real values.
#  NEVER commit the real ".env" file (it is git-ignored).
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (e.g. from Neon).
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# OpenRouter API Key
OPENROUTER_API_KEY="your_openrouter_api_key"

# Groq API Key
GROQ_API_KEY="your_groq_api_key"

# FarazSMS API Configuration (optional for now)
# Current auth works with mobile/username + password. Fill these later when SMS/OTP is enabled.
FARAZSMS_API_KEY="your_api_key_from_farazsms"
FARAZSMS_PATTERN_CODE="your_pattern_code"
FARAZSMS_SENDER="+983000505"

# Node environment: development | production
NODE_ENV="development"
