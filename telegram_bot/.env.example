# توکن ربات را از BotFather بگیرید و اینجا بگذارید
BOT_TOKEN=123456789:REPLACE_ME

# آیدی عددی ادمین‌ها؛ اگر چند نفرند با کاما جدا کنید
# برای گرفتن آیدی می‌توانید به @userinfobot پیام بدهید
ADMIN_IDS=123456789

# برند و آدرس وب‌اپ گیمنت
BRAND_NAME=Gament
TOURNAMENT_TITLE=Gament — پلتفرم تورنومنت گیمینگ
APP_URL=https://gament-1.onrender.com
SUPPORT_URL=https://gament-1.onrender.com/profile
CHANNEL_URL=

# بازی‌های اصلی گیمنت
GAMES=COD MOBILE,FORTNITE,CLASH ROYALE
PLATFORMS=Mobile,PC,Console,PS5,PS4,Xbox,Nintendo Switch,Other

# اگر true باشد کاربر حتماً باید Gament ID مثل FLX-1234 وارد کند
GAMENT_ID_REQUIRED=false

# اتصال مستقیم ربات به وب‌اپ Gament
# این مقدار باید دقیقاً با TELEGRAM_INTEGRATION_SECRET در env وب‌اپ یکی باشد.
TELEGRAM_INTEGRATION_SECRET=change_this_to_a_long_random_secret

# مسیر دیتابیس SQLite ربات تلگرام
DB_PATH=gament_telegram_bot.db

# متن قوانین؛ اگر خالی بماند متن پیش‌فرض گیمنت استفاده می‌شود
RULES_TEXT=

# اطلاعات پرداخت/ورودی؛ ترجیحاً پرداخت رسمی از داخل وب‌اپ انجام شود
PAYMENT_INFO=پرداخت ورودی تورنومنت‌ها، در صورت وجود، از طریق کیف پول وب‌اپ گیمنت انجام می‌شود.
